# =============================================================================
# Zajazd Sezam — zmienne środowiskowe
# Skopiuj do .env.local i wypełnij. NIGDY nie commituj .env.local.
# =============================================================================

# --- Site ---
# Pełny URL strony. Lokalnie: http://localhost:3000. Produkcja: https://zajazdsezam.pl
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Sanity CMS ---
# Wartości po utworzeniu projektu na https://sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-05-16
# Read-only token dla Next.js (Sanity Studio → API → Tokens → Viewer)
SANITY_API_TOKEN=
# Sekret do weryfikacji webhooków rewalidacji ISR (dowolny losowy string, min. 32 znaki)
SANITY_WEBHOOK_SECRET=

# --- Cloudflare Turnstile ---
# Dev: test keys Cloudflare (zawsze przepuszczają)
# Docs: https://developers.cloudflare.com/turnstile/troubleshooting/testing/
# Site key (always passes):     1x00000000000000000000AA
# Secret key (always passes):   1x0000000000000000000000000000000AA
# Produkcja: prawdziwe klucze z https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# --- Email (Resend) ---
# Lokalnie: zostaw RESEND_API_KEY puste — emaile będą zapisywane do tmp/mails/*.html
# Produkcja: klucz z https://resend.com/api-keys + verify domeny
RECEPTION_EMAIL=recepcja@zajazdsezam.pl
REPLY_FROM_EMAIL=
RESEND_API_KEY=

# --- Google ---
# Places API key (opinie). Lokalnie: zostaw puste → mock data
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
# Maps Embed API key (mapa na /kontakt). Lokalnie: zostaw puste → placeholder
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY=

# --- Analytics ---
# GA4 Measurement ID. Lokalnie: zostaw puste → komponent no-op
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
